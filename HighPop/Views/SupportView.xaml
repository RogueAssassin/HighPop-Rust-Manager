<UserControl x:Class="HighPop.Views.SupportView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:HighPop"
             Background="{StaticResource BgDeepBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
        <StackPanel MaxWidth="760" HorizontalAlignment="Left">
            <Image Source="pack://application:,,,/HighPop;component/assets/brand/highpop.png"
                   Width="330" Height="70" Stretch="Uniform" HorizontalAlignment="Left"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock Text="Local-first Windows control for serious Rust communities."
                       FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,8,0,28"/>

            <TextBlock Text="ABOUT" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Version" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="{x:Static app:AppInfo.VersionDisplay}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="Check for update" Style="{StaticResource GhostButton}" FontSize="11"
                                    Margin="14,0,0,0" Command="{Binding CheckForWgsUpdateNowCommand}"
                                    IsEnabled="{Binding UpdateDownloading, Converter={StaticResource InvBool}}"/>
                            <TextBlock Text="{Binding WgsUpdateCheckResult}" Margin="10,0,0,0" FontSize="11"
                                       VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Row="1" Text="Maintainer" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="HighPop Contributors" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="2" Text="Platform" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text=".NET 10 · WPF · Windows x64" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="3" Text="License" Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="MIT — source available on GitHub" FontWeight="SemiBold"/>
                    </Grid>

                    <StackPanel Margin="150,14,0,0" Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Stop running servers before installing an update."
                                   Foreground="{StaticResource AccentYellowBrush}" FontSize="11" Margin="0,0,0,7"
                                   Visibility="{Binding HasRunningServers, Converter={StaticResource BoolToVis}}"/>
                        <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"
                                Content="Install available update" Command="{Binding PerformUpdateCommand}"
                                IsEnabled="{Binding CanInstallUpdate}"/>
                        <StackPanel Margin="0,8,0,0" Visibility="{Binding UpdateDownloading, Converter={StaticResource BoolToVis}}">
                            <ProgressBar IsIndeterminate="True" Height="4"/>
                            <TextBlock Text="{Binding UpdateStatusText}" FontSize="11" Margin="0,5,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="RUST OPERATIONS" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,24">
                <WrapPanel>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="SteamCMD" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="WebRCON" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Carbon + Oxide" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Safe wipes" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Backups + restore" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Players + bans" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Schedulers" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Discord + email" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="REST dashboard" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                    <Border Style="{StaticResource Card}" Padding="10,6" Margin="0,0,8,8"><TextBlock Text="Portable assets" Foreground="{StaticResource AccentBlueBrush}"/></Border>
                </WrapPanel>
            </Border>

            <TextBlock Text="PROJECT" FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="HighPop Rust Manager" FontSize="17" FontWeight="Bold"/>
                    <TextBlock Text="Report issues, review the source, or contribute a pull request."
                               TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,7,0,15"/>
                    <Button Content="Open GitHub repository" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Left" Padding="18,9" Click="GitHubButton_Click"/>
                    <TextBlock Text="Built on the MIT-licensed Windows Game Server project. Other managers informed the feature research; their proprietary and GPL code is not included."
                               TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,18,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
