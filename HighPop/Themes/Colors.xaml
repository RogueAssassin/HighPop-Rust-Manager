<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background layers -->
    <Color x:Key="BgDeepColor">#0B0D12</Color>
    <Color x:Key="BgSurfaceColor">#111319</Color>
    <Color x:Key="BgSurface2Color">#191C24</Color>
    <Color x:Key="BgSurface3Color">#232731</Color>

    <!-- Accent colors -->
    <Color x:Key="AccentBlueColor">#F05A28</Color>
    <Color x:Key="AccentGreenColor">#38C976</Color>
    <Color x:Key="AccentRedColor">#FF5D5D</Color>
    <Color x:Key="AccentYellowColor">#FFB020</Color>
    <Color x:Key="AccentOrangeColor">#FF8A3D</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#F7F7F2</Color>
    <Color x:Key="TextSecondaryColor">#A6ADBB</Color>
    <Color x:Key="TextMutedColor">#697181</Color>

    <!-- Border -->
    <Color x:Key="BorderColor">#2A2F3A</Color>
    <Color x:Key="BorderActiveColor">#F05A28</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgDeepBrush"     Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush"  Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgSurface2Brush" Color="{StaticResource BgSurface2Color}"/>
    <SolidColorBrush x:Key="BgSurface3Brush" Color="{StaticResource BgSurface3Color}"/>

    <SolidColorBrush x:Key="AccentBlueBrush"   Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"  Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentRedBrush"    Color="{StaticResource AccentRedColor}"/>
    <SolidColorBrush x:Key="AccentYellowBrush" Color="{StaticResource AccentYellowColor}"/>
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderActiveBrush"  Color="{StaticResource BorderActiveColor}"/>
    <SolidColorBrush x:Key="TransparentBrush"   Color="Transparent"/>
    <!-- Shared Files-page selection palette, used across lists and dropdowns. -->
    <SolidColorBrush x:Key="SelectionActiveBrush" Color="#4A2A1E"/>
    <SolidColorBrush x:Key="SelectionInactiveBrush" Color="#30231F"/>

</ResourceDictionary>
